---
// Current date context for defaulting values dynamically in 2026
const currentMonth = new Date().getMonth();
const currentYear = new Date().getFullYear();

const months = [
  { value: 0, label: 'January' },
  { value: 1, label: 'February' },
  { value: 2, label: 'March' },
  { value: 3, label: 'April' },
  { value: 4, label: 'May' },
  { value: 5, label: 'June' },
  { value: 6, label: 'July' },
  { value: 7, label: 'August' },
  { value: 8, label: 'September' },
  { value: 9, label: 'October' },
  { value: 10, label: 'November' },
  { value: 11, label: 'December' }
];

// Generate an array of years centered around the current project launch timeline
const years = [2025, 2026, 2027];
---

<div class="bg-white border border-sky-100/40 rounded-2xl p-4 shadow-sm flex items-center gap-3">
  <div class="flex-1 relative">
    <label for="month-select" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Month</label>
    <select
      id="month-select"
      class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200 appearance-none touch-manipulation"
    >
      {months.map((m) => (
        <option value={m.value} selected={m.value === currentMonth}>{m.label}</option>
      ))}
    </select>
    <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </div>

  <div class="w-28 relative">
    <label for="year-select" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Year</label>
    <select
      id="year-select"
      class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200 appearance-none touch-manipulation"
    >
      {years.map((y) => (
        <option value={y} selected={y === currentYear}>{y}</option>
      ))}
    </select>
    <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </div>
</div>

<script>
  // Monitor dropdown changes to emit updates for the parent layout views
  const monthSelect = document.getElementById('month-select') as HTMLSelectElement;
  const yearSelect = document.getElementById('year-select') as HTMLSelectElement;

  function dispatchDateChange() {
    const event = new CustomEvent('date-filter-change', {
      detail: {
        month: parseInt(monthSelect.value, 10),
        year: parseInt(yearSelect.value, 10)
      }
    });
    window.dispatchEvent(event);
  }

  monthSelect?.addEventListener('change', dispatchDateChange);
  yearSelect?.addEventListener('change', dispatchDateChange);
</script>
