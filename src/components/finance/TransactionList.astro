---
interface Transaction {
  id: string;
  description: string;
  amount: number;
  date: string;
  created_by_user_id: string;
}

interface Props {
  transactions: Transaction[];
}

const { transactions = [] } = Astro.props;

const formatCurrency = (amountInPence: number) => {
  const absoluteValue = Math.abs(amountInPence / 100).toFixed(2)
  return `£${absoluteValue}`
}
---

<div class="space-y-3">
  <div class="flex items-center justify-between px-1">
    <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Recent Activity</h3>
    <span class="text-xs font-semibold text-sky-700 bg-sky-100/70 px-2.5 py-0.5 rounded-full">This Month</span>
  </div>

  {transactions.length === 0 ? (
    <div class="bg-white/60 border border-dashed border-sky-100 rounded-2xl p-8 text-center shadow-inner">
      <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 medical-icon text-slate-400">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <p class="text-sm text-slate-400 font-medium">No transactions recorded yet</p>
    </div>
  ) : (
    <div class="flex flex-col gap-2.5">
      {transactions.map((tx) => {
        const isExpense = tx.amount < 0
        
        return (
          <div class="w-full bg-white border border-sky-100/40 rounded-xl p-4 flex items-center justify-between shadow-sm active:bg-slate-50 transition-colors touch-manipulation cursor-pointer select-none">
            <div class="flex items-center gap-3">
              <div class={`w-10 h-10 rounded-xl flex items-center justify-center font-bold text-lg ${isExpense ? 'bg-rose-50 text-rose-600' : 'bg-emerald-50 text-emerald-600'}`}>
                {isExpense ? '−' : '+'}
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-700 leading-tight">{tx.description}</p>
                <p class="text-[11px] font-medium text-slate-400 mt-1">{tx.date}</p>
              </div>
            </div>
            
            <div class="text-right">
              <p class={`text-sm font-bold ${isExpense ? 'text-slate-700' : 'text-emerald-600'}`}>
                {isExpense ? '' : '+'}{formatCurrency(tx.amount)}
              </p>
              <span class="inline-block text-[9px] font-bold tracking-wide uppercase bg-slate-50 text-slate-400 border border-slate-100 px-1.5 py-0.5 rounded-md mt-1">
                Household Split
              </span>
            </div>
          </div>
        )
      })}
    </div>
  )}
</div>
