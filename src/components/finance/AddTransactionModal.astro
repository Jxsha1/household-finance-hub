---
import Button from '../ui/Button.astro'
---

<div class="w-full">
  <button
    id="open-modal-btn"
    class="w-full h-12 bg-gradient-to-r from-sky-200 to-emerald-200 text-slate-700 hover:from-sky-300 hover:to-emerald-300 font-bold text-xs tracking-wide rounded-xl flex items-center justify-center gap-2 transition-all shadow-sm touch-manipulation cursor-pointer active:scale-[0.99]"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 text-slate-600">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    Log Manual Expense Item
  </button>
</div>

<div 
  id="transaction-modal" 
  class="fixed inset-0 z-50 bg-slate-900/30 backdrop-blur-sm flex items-end sm:items-center justify-center p-0 sm:p-4 hidden"
>
  <div 
    id="modal-sheet"
    class="w-full sm:max-w-md bg-white rounded-t-3xl sm:rounded-3xl border-t sm:border border-sky-100/60 p-6 shadow-xl transform translate-y-full transition-transform duration-300 ease-out pb-safe"
  >
    <div class="flex items-center justify-between mb-5">
      <div>
        <h3 class="text-sm font-bold text-slate-700">Log Cash Outflow</h3>
        <p class="text-[11px] text-slate-400 mt-0.5">Record ad hoc manual family expenditures instantly</p>
      </div>
      <button 
        id="close-modal-btn" 
        type="button" 
        class="w-8 h-8 rounded-full bg-slate-50 border border-slate-100 flex items-center justify-center text-slate-400 hover:text-slate-600 cursor-pointer touch-manipulation"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <form id="modal-transaction-form" class="space-y-4">
      <div id="modal-form-error" class="hidden bg-rose-50 border border-rose-100 text-rose-800 text-xs font-semibold p-3 rounded-xl text-center"></div>

      <div class="relative">
        <label for="modal-description" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Merchant / Purpose</label>
        <input 
          type="text" 
          id="modal-description" 
          required 
          placeholder="e.g. Corner Shop Milk / Fuel" 
          class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200 transition-all touch-manipulation"
        />
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div class="relative">
          <label for="modal-amount" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Amount (Pounds)</label>
          <input 
            type="number" 
            step="0.01" 
            id="modal-amount" 
            required 
            placeholder="0.00" 
            class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200 transition-all touch-manipulation"
          />
        </div>

        <div class="relative">
          <label for="modal-date" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Transaction Date</label>
          <input 
            type="date" 
            id="modal-date" 
            required 
            class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200 transition-all touch-manipulation"
          />
        </div>
      </div>

      <div class="pt-2 flex gap-3">
        <Button type="submit" id="modal-submit-btn" variant="primary" className="flex-1 h-12">
          Commit Ledger Record
        </Button>
      </div>
    </form>
  </div>
</div>

<script>
  const openBtn = document.getElementById('open-modal-btn')
  const closeBtn = document.getElementById('close-modal-btn')
  const modal = document.getElementById('transaction-modal')
  const sheet = document.getElementById('modal-sheet')
  const form = document.getElementById('modal-transaction-form') as HTMLFormElement
  const errorBox = document.getElementById('modal-form-error')
  const submitBtn = document.getElementById('modal-submit-btn')

  // Automatically default the input widget to the current calendar date structure
  const dateInput = document.getElementById('modal-date') as HTMLInputElement
  if (dateInput) {
    dateInput.value = new Date().toISOString().split('T')[0]
  }

  function openModal() {
    modal?.classList.remove('hidden')
    setTimeout(() => {
      sheet?.classList.remove('translate-y-full')
    }, 10)
  }

  function closeModal() {
    sheet?.classList.add('translate-y-full')
    setTimeout(() => {
      modal?.classList.add('hidden')
      if (errorBox) errorBox.classList.add('hidden')
      form?.reset()
    }, 300)
  }

  openBtn?.addEventListener('click', openModal)
  closeBtn?.addEventListener('click', closeModal)
  
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal()
  })

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!errorBox || !submitBtn) return

    errorBox.classList.add('hidden')
    submitBtn.textContent = 'Saving to database...'
    ;(submitBtn as HTMLButtonElement).disabled = true

    const description = (document.getElementById('modal-description') as HTMLInputElement).value
    const rawAmount = parseFloat((document.getElementById('modal-amount') as HTMLInputElement).value)
    const date = (document.getElementById('modal-date') as HTMLInputElement).value

    // Force inverted absolute integer values since modal inputs represent expenses out of the household
    const amount = -Math.abs(Math.round(rawAmount * 100))

    try {
      const response = await fetch('/api/transactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ description, amount, date })
      })

      const data = await response.json()

      if (!response.ok) {
        throw new Error(data.error || 'Failed to record entry transaction parameters')
      }

      closeModal()
      
      // Force an application reload to fetch the fresh server-side data logs instantly
      window.location.reload()
    } catch (err: any) {
      errorBox.textContent = err.message
      errorBox.classList.remove('hidden')
      submitBtn.textContent = 'Commit Ledger Record'
      ;(submitBtn as HTMLButtonElement).disabled = false
    }
  })
</script>