---
interface Props {
  type?: 'button' | 'submit';
  variant?: 'primary' | 'secondary' | 'danger';
  className?: string;
  id?: string;
}

const { type = 'button', variant = 'primary', className = '', id } = Astro.props;

const baseStyles = 'w-full h-12 px-6 rounded-xl font-semibold text-sm tracking-wide flex items-center justify-center transition-all duration-200 active:scale-[0.98] select-none touch-manipulation focus:outline-none focus:ring-2 focus:ring-offset-2';

const variants = {
  primary: 'bg-sky-200 text-sky-900 hover:bg-sky-300 active:bg-sky-400 focus:ring-sky-300 shadow-sm shadow-sky-100',
  secondary: 'bg-emerald-100 text-emerald-900 hover:bg-emerald-200 active:bg-emerald-300 focus:ring-emerald-200 shadow-sm shadow-emerald-50',
  danger: 'bg-rose-100 text-rose-900 hover:bg-rose-200 active:bg-rose-300 focus:ring-rose-200 shadow-sm'
};

const combinedStyles = `${baseStyles} ${variants[variant]} ${className}`;
---

<button type={type} id={id} class={combinedStyles}>
  <slot />
</button>
