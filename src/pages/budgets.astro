---
import MainLayout from '../layouts/MainLayout.astro'
import Card from '../components/ui/Card.astro'
---

<MainLayout title="Budget Envelopes">
  <div class="space-y-4">
    <Card>
      <div class="mb-2">
        <h2 class="text-sm font-bold text-slate-700">Category Envelopes</h2>
        <p class="text-xs text-slate-400 mt-0.5">Allocate targeted limits to manage financial anxiety</p>
      </div>
      <div class="bg-slate-50 border border-slate-100 rounded-xl p-6 text-center text-xs text-slate-400 font-medium">
        Zero-Based budgeting envelope configurations and progression caps will load here during Phase 4
      </div>
    </Card>
  </div>
</MainLayout>
