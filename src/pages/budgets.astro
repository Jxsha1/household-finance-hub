---
import MainLayout from '../layouts/MainLayout.astro'
import Card from '../components/ui/Card.astro'
import Button from '../components/ui/Button.astro'

const db = (Astro.locals as any).runtime?.env?.DB
const user = (Astro.locals as any).user

if (!db || !user) {
  return Astro.redirect('/login')
}

// Extract historical and operational standing commitments from the cloud database node
const { results } = await db.prepare(
  'SELECT id, name, amount, direction, bank_name, day_of_month, start_date, end_date FROM recurring_payments WHERE household_id = ? ORDER BY end_date ASC, direction DESC, day_of_month ASC'
).bind(user.householdId).all()

const recurringPayments = results || []

const formatCurrency = (pence: number) => {
  return `£${(Math.abs(pence) / 100).toFixed(2)}`
}
---

<MainLayout title="Recurring Commitments">
  <div class="space-y-5">
    
    <Card>
      <div class="mb-4">
        <h2 id="form-title" class="text-sm font-bold text-slate-700">Add Recurring Standing Order / Direct Debit</h2>
        <p class="text-xs text-slate-400 mt-0.5">Manually log fixed household salary influxes or bank outgoings</p>
      </div>

      <form id="recurring-form" data-mode="create" data-edit-id="" class="space-y-3">
        <div id="form-error-banner" class="hidden bg-rose-50 border border-rose-100 text-rose-800 text-xs font-semibold p-3 rounded-xl text-center"></div>

        <div class="grid grid-cols-2 gap-3">
          <div class="relative">
            <label for="direction" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Stream Type</label>
            <select id="direction" class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 appearance-none focus:outline-none focus:ring-2 focus:ring-sky-200">
              <option value="OUT">Expense (OUT)</option>
              <option value="IN">Income (IN)</option>
            </select>
          </div>
          <div class="relative">
            <label for="bank_name" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Source Bank Account</label>
            <select id="bank_name" class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 appearance-none focus:outline-none focus:ring-2 focus:ring-sky-200">
              <option value="Barclays">Barclays</option>
              <option value="Halifax">Halifax</option>
              <option value="HSBC">HSBC</option>
              <option value="Lloyds">Lloyds</option>
              <option value="Monzo">Monzo</option>
              <option value="NatWest">NatWest</option>
              <option value="Santander">Santander</option>
              <option value="CUSTOM">Other / Add New...</option>
            </select>
          </div>
        </div>

        <div id="custom-bank-container" class="relative hidden">
          <label for="custom_bank_name" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Custom Bank Name</label>
          <input type="text" id="custom_bank_name" placeholder="e.g. TSB / Nationwide" class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200" />
        </div>

        <div class="relative">
          <label for="name" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Payment Description</label>
          <input type="text" id="name" required placeholder="e.g. Council Tax / Rent" class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200" />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="relative">
            <label for="amount" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Amount (Pounds)</label>
            <input type="number" step="0.01" id="amount" required placeholder="0.00" class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200" />
          </div>
          <div class="relative">
            <label for="day_of_month" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Due Day of Month</label>
            <input type="number" min="1" max="31" id="day_of_month" required placeholder="e.g. 1st" class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="relative">
            <label for="start_date" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">Start Date</label>
            <input type="date" id="start_date" required class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200" />
          </div>
          <div class="relative">
            <label for="end_date_input" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">End Date (Optional)</label>
            <input type="date" id="end_date_input" class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200" />
          </div>
        </div>

        <div class="flex gap-2 pt-1">
          <Button type="submit" id="submit-commitment-btn" variant="secondary" className="flex-1">Save Recurring Commitment</Button>
          <button type="button" id="cancel-edit-btn" class="hidden px-4 bg-slate-100 text-slate-600 hover:bg-slate-200 font-semibold text-xs rounded-xl transition-all">Cancel</button>
        </div>
      </form>
    </Card>

    <Card>
      <div class="mb-3">
        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Registered Standing Commitments</h3>
      </div>

      {recurringPayments.length === 0 ? (
        <p class="text-xs text-slate-400 text-center py-4">No fixed monthly recurring items registered yet</p>
      ) : (
        <div class="space-y-2.5">
          {recurringPayments.map((p: any) => {
            const hasEnded = p.end_date && new Date(p.end_date) < new Date()
            return (
              <div class={`bg-slate-50 border border-slate-100 rounded-xl p-3 flex flex-col justify-between gap-3 text-xs transition-opacity ${hasEnded ? 'opacity-40' : ''}`}>
                <div class="flex items-start justify-between">
                  <div>
                    <p class="font-bold text-slate-700">
                      {p.name}
                      {hasEnded && <span class="ml-1.5 text-[9px] font-bold uppercase text-rose-700 bg-rose-50 border border-rose-100 px-1 py-0.5 rounded">Ended</span>}
                    </p>
                    <p class="text-[10px] text-slate-400 mt-0.5">Bank: {p.bank_name} · Day {p.day_of_month} · From: {p.start_date}{p.end_date ? ` to ${p.end_date}` : ''}</p>
                  </div>
                  <span class={p.direction === 'IN' ? 'text-emerald-600 font-bold' : 'text-slate-600 font-bold'}>
                    {p.direction === 'IN' ? '+' : '−'}{formatCurrency(p.amount)}
                  </span>
                </div>

                <div class="flex gap-2 border-t border-slate-100/70 pt-2">
                  <button 
                    type="button"
                    class="edit-btn text-[10px] font-bold text-sky-700 bg-sky-50 hover:bg-sky-100/80 px-2.5 py-1 rounded-md transition-colors"
                    data-id={p.id}
                    data-name={p.name}
                    data-amount={(p.amount / 100).toFixed(2)}
                    data-direction={p.direction}
                    data-bank={p.bank_name}
                    data-day={p.day_of_month}
                    data-start={p.start_date}
                    data-end={p.end_date || ''}
                  >
                    Modify
                  </button>
                  {!p.end_date && (
                    <button 
                      type="button"
                      class="delete-btn text-[10px] font-bold text-rose-700 bg-rose-50 hover:bg-rose-100/80 px-2.5 py-1 rounded-md transition-colors"
                      data-id={p.id}
                    >
                      Stop Payment
                    </button>
                  )}
                </div>
              </div>
            )
          })}
        </div>
      )}
    </Card>
  </div>
</MainLayout>

<script>
  const form = document.getElementById('recurring-form') as HTMLFormElement;
  const formTitle = document.getElementById('form-title');
  const errorBanner = document.getElementById('form-error-banner');
  const submitBtn = document.getElementById('submit-commitment-btn');
  const cancelEditBtn = document.getElementById('cancel-edit-btn') as HTMLButtonElement;
  const bankSelect = document.getElementById('bank_name') as HTMLSelectElement;
  const customBankContainer = document.getElementById('custom-bank-container');
  const customBankInput = document.getElementById('custom_bank_name') as HTMLInputElement;

  const startInput = document.getElementById('start_date') as HTMLInputElement;
  if (startInput && !startInput.value) {
    startInput.value = new Date().toISOString().split('T')[0];
  }

  const PRESET_BANKS = ['Barclays', 'Halifax', 'HSBC', 'Lloyds', 'Monzo', 'NatWest', 'Santander'];

  bankSelect?.addEventListener('change', () => {
    if (bankSelect.value === 'CUSTOM') {
      customBankContainer?.classList.remove('hidden');
      customBankInput.required = true;
    } else {
      customBankContainer?.classList.add('hidden');
      customBankInput.required = false;
      customBankInput.value = '';
    }
  });

  // Handle Edit selection mapping routines
  document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      if (!form || !formTitle || !cancelEditBtn) return;

      formTitle.textContent = 'Amend Recurring Commitment';
      form.setAttribute('data-mode', 'edit');
      form.setAttribute('data-edit-id', target.getAttribute('data-id') || '');
      cancelEditBtn.classList.remove('hidden');

      (document.getElementById('direction') as HTMLSelectElement).value = target.getAttribute('data-direction') || 'OUT';
      (document.getElementById('name') as HTMLInputElement).value = target.getAttribute('data-name') || '';
      (document.getElementById('amount') as HTMLInputElement).value = target.getAttribute('data-amount') || '';
      (document.getElementById('day_of_month') as HTMLInputElement).value = target.getAttribute('data-day') || '';
      
      const bank = target.getAttribute('data-bank') || '';
      if (PRESET_BANKS.includes(bank)) {
        bankSelect.value = bank;
        customBankContainer?.classList.add('hidden');
        customBankInput.required = false;
      } else {
        bankSelect.value = 'CUSTOM';
        customBankContainer?.classList.remove('hidden');
        customBankInput.required = true;
        customBankInput.value = bank;
      }

      // Default the start date field box to today for the new amended variant chain
      startInput.value = new Date().toISOString().split('T')[0];
      (document.getElementById('end_date_input') as HTMLInputElement).value = target.getAttribute('data-end') || '';
      
      window.scrollTo({ top: 0, behaviour: 'smooth' });
    });
  });

  // Trigger automated soft delete configurations
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.getAttribute('data-id');
      const stopDate = prompt('Enter the final end date for this payment structure (YYYY-MM-DD):', new Date().toISOString().split('T')[0]);
      
      if (!id || stopDate === null) return;

      try {
        const response = await fetch('/api/recurring', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, end_date: stopDate })
        });
        if (!response.ok) throw new Error('Could not record cancellation status');
        window.location.reload();
      } catch (err: any) {
        alert(err.message);
      }
    });
  });

  cancelEditBtn?.addEventListener('click', () => {
    form.reset();
    form.setAttribute('data-mode', 'create');
    form.setAttribute('data-edit-id', '');
    if (formTitle) formTitle.textContent = 'Add Recurring Standing Order / Direct Debit';
    cancelEditBtn.classList.add('hidden');
    customBankContainer?.classList.add('hidden');
    startInput.value = new Date().toISOString().split('T')[0];
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!errorBanner || !submitBtn) return;

    errorBanner.classList.add('hidden');
    submitBtn.textContent = 'Saving structural timeline updates...';
    (submitBtn as HTMLButtonElement).disabled = true;
    
    const mode = form.getAttribute('data-mode');
    const editId = form.getAttribute('data-edit-id');

    const direction = (document.getElementById('direction') as HTMLSelectElement).value;
    let bank_name = bankSelect.value;
    if (bank_name === 'CUSTOM') {
      bank_name = customBankInput.value.trim();
    }
    
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const rawAmount = parseFloat((document.getElementById('amount') as HTMLInputElement).value);
    const day_of_month = parseInt((document.getElementById('day_of_month') as HTMLInputElement).value, 10);
    const start_date = startInput.value;
    
    const amount = Math.round(rawAmount * 100);

    const payload: any = { name, amount, direction, bank_name, day_of_month, start_date };
    if (mode === 'edit') payload.id = editId;

    try {
      const response = await fetch('/api/recurring', {
        method: mode === 'edit' ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const data = await response.json();
      if (!response.ok) throw new Error(data.error || 'Failed to submit commitment timeline rows');

      window.location.reload();
    } catch (err: any) {
      errorBanner.textContent = err.message;
      errorBanner.classList.remove('hidden');
      submitBtn.textContent = 'Save Recurring Commitment';
      (submitBtn as HTMLButtonElement).disabled = false;
    }
  });
</script>
