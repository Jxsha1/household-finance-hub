---
import MainLayout from '../layouts/MainLayout.astro'
import BudgetToggle from '../components/finance/BudgetToggle.astro'
import MonthYearSelector from '../components/finance/MonthYearSelector.astro'
import TransactionList from '../components/finance/TransactionList.astro'
import StatementUpload from '../components/finance/StatementUpload.astro'

const db = (Astro.locals as any).runtime?.env?.DB
const user = (Astro.locals as any).user

if (!db || !user) {
  return Astro.redirect('/login')
}

// Fetch the household configuration parameters and recent ledger transactions via parallel promises
const [householdResult, transactionsResult] = await Promise.all([
  db.prepare('SELECT budget_mode FROM households WHERE id = ?').bind(user.householdId).first(),
  db.prepare('SELECT id, description, amount, date, created_by_user_id FROM transactions WHERE household_id = ? ORDER BY date DESC, created_at DESC LIMIT 20').bind(user.householdId).all()
])

const budgetMode = (householdResult?.budget_mode as 'cash_flow' | 'zero_based') || 'cash_flow'
const transactions = (transactionsResult?.results as any[]) || []
---

<MainLayout title="Household Dashboard">
  <div slot="header-actions" class="flex items-center gap-1.5 bg-emerald-50 border border-emerald-100/80 px-2.5 py-1 rounded-full">
    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
    <span class="text-[10px] font-bold text-emerald-800 uppercase tracking-wider">Cloud Connected</span>
  </div>

  <div class="space-y-5">
    
    <MonthYearSelector />
    
    <BudgetToggle currentMode={budgetMode} />

    <StatementUpload />

    <TransactionList transactions={transactions} />
    
  </div>
</MainLayout>

<script>
  import '../lib/pdfParser.ts'

  window.addEventListener('date-filter-change', (event: any) => {
    const { month, year } = event.detail
    console.log(`Refetch triggering for date window context: ${month} in year: ${year}`)
  })
</script>
