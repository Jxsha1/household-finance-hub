---
import MainLayout from '../layouts/MainLayout.astro'
import Card from '../components/ui/Card.astro'
---

<MainLayout title="Historical Activity">
  <div class="space-y-4">
    <Card>
      <div class="mb-2">
        <h2 class="text-sm font-bold text-slate-700">Transaction History</h2>
        <p class="text-xs text-slate-400 mt-0.5">A complete audit ledger of your shared household cash flow</p>
      </div>
      <div class="bg-slate-50 border border-slate-100 rounded-xl p-6 text-center text-xs text-slate-400 font-medium">
        Detailed database lookup filters and transaction editing modules will load here during Phase 4
      </div>
    </Card>
  </div>
</MainLayout>
