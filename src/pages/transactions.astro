---
import MainLayout from '../layouts/MainLayout.astro'
import TransactionList from '../components/finance/TransactionList.astro'

const db = (Astro.locals as any).runtime?.env?.DB
const user = (Astro.locals as any).user

if (!db || !user) {
  return Astro.redirect('/login')
}

// Fetch all historical ledger items tied to the active household account profile
const { results } = await db.prepare(
  'SELECT id, description, amount, date, created_by_user_id FROM transactions WHERE household_id = ? ORDER BY date DESC, created_at DESC'
).bind(user.householdId).all()

const transactions = (results as any[]) || []
---

<MainLayout title="Historical Ledger">
  <div class="space-y-4">
    <div class="bg-white border border-sky-100/40 rounded-2xl p-5 shadow-sm">
      <h2 class="text-sm font-bold text-slate-700">Audit History</h2>
      <p class="text-xs text-slate-400 mt-0.5">A complete chronological log of all shared household cash flow updates</p>
    </div>

    <TransactionList transactions={transactions} />
  </div>
</MainLayout>
