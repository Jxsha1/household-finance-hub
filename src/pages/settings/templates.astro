templateConfig[currentTargetMode] = { x: pctX, y: pctY, w: pctW, h: pctH }
    if (logs) logs.textContent = JSON.stringify(templateConfig, null, 2)
  })

  // Wire up the asynchronous network submission handler to lock down coordinates in D1 storage
  saveBtn?.addEventListener('click', async () => {
    if (!saveBtn || !logs) return

    const bankName = (document.getElementById('template-bank') as HTMLSelectElement).value
    saveBtn.textContent = 'Synchronising layout rules...'
    ;(saveBtn as HTMLButtonElement).disabled = true

    try {
      const response = await fetch('/api/templates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          bankName,
          rate: templateConfig.rate,
          min: templateConfig.min
        })
      })

      const data = await response.json()
      if (!response.ok) throw new Error(data.error || 'Failed to preserve layout alignment rules')

      saveBtn.textContent = 'Blueprint Saved Successfully'
      logs.textContent = 'Template registered to database configuration log chains safely.'
      
      setTimeout(() => {
        saveBtn.textContent = 'Save Structural Blueprint'
        ;(saveBtn as HTMLButtonElement).disabled = false
      }, 2000)
    } catch (err: any) {
      logs.textContent = 'Error: ' + err.message
      saveBtn.textContent = 'Save Structural Blueprint'
      ;(saveBtn as HTMLButtonElement).disabled = false
    }
  })
</script>
