---
import MainLayout from '../layouts/MainLayout.astro'
import Card from '../components/ui/Card.astro'
import Button from '../components/ui/Button.astro'

const user = (Astro.locals as any).user
const isForced = user?.passwordChangeRequired === 1 || Astro.url.searchParams.get('force') === '1'
---

<MainLayout title="System Settings">
  <div slot="header-actions" class="flex items-center gap-1.5 bg-emerald-50 border border-emerald-100/80 px-2.5 py-1 rounded-full">
    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
    <span class="text-[10px] font-bold text-emerald-800 uppercase tracking-wider">Cloud Connected</span>
  </div>

  <div class="space-y-4">
    {isForced && (
      <div class="bg-rose-50 border border-rose-100 text-rose-900 text-xs font-semibold p-4 rounded-2xl text-center shadow-sm">
        <p class="font-bold text-rose-800 text-sm mb-1">Password Change Required</p>
        <p class="text-slate-500 font-medium leading-relaxed">This is your first login session. You must update your access credentials before you can browse the shared family dashboards.</p>
      </div>
    )}

    <Card>
      <div class="mb-4">
        <h2 class="text-sm font-bold text-slate-700">Update Account Password</h2>
        <p class="text-xs text-slate-400 mt-0.5">Ensure your security profile remains completely uncompromised</p>
      </div>

      <form id="password-form" class="space-y-3">
        <div id="password-message" class="hidden text-xs font-semibold p-3 rounded-xl text-center"></div>

        <div class="relative">
          <label for="new-password" class="absolute left-3 top-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-wider">New Secure Password</label>
          <input
            type="password"
            id="new-password"
            required
            minlength="6"
            placeholder="••••••••"
            class="w-full h-12 pt-4 pb-1 px-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-200 transition-all touch-manipulation"
          />
        </div>

        <Button type="submit" id="password-submit-btn" variant="secondary">
          Save New Password
        </Button>
      </form>
    </Card>

    {!isForced && (
      <>
        <Card>
          <div class="mb-4">
            <h2 class="text-sm font-bold text-slate-700">Device Notifications</h2>
            <p class="text-xs text-slate-400 mt-0.5">Receive alerts regarding household budget warnings</p>
          </div>
          <div id="push-status-message" class="hidden text-xs font-semibold p-3 mb-3 rounded-xl text-center"></div>
          <Button id="push-toggle" variant="primary">
            Enable Mobile Push Notifications
          </Button>
        </Card>

        <Card>
          <div class="mb-2">
            <h2 class="text-sm font-bold text-slate-700">Account Access</h2>
            <p class="text-xs text-slate-400 mt-0.5">Logged in as a shared household participant</p>
          </div>
          <Button id="sign-out-btn" variant="danger" className="mt-2">
            Sign Out Securely
          </Button>
        </Card>
      </>
    )}
  </div>
</MainLayout>

<script>
  const passwordForm = document.getElementById('password-form') as HTMLFormElement;
  const passwordMessage = document.getElementById('password-message');
  const passwordSubmitBtn = document.getElementById('password-submit-btn');
  const signOutBtn = document.getElementById('sign-out-btn');
  const pushToggleBtn = document.getElementById('push-toggle') as HTMLButtonElement;
  const pushStatusMessage = document.getElementById('push-status-message');

  // Placeholder VAPID key pair target required for push registration handshakes
  const VAPID_PUBLIC_KEY = 'BEl62OhSreZREf9661s2K6Z909Yc30n_n4O_G1TzGvWz_jE_vQc_qP_s49_X8';

  function urlBase64ToUint8Array(base64String: string) {
    const padding = '='.repeat((4 - base64String.length % 4) % 4);
    const base64 = (base64String + padding).replace(/\-/g, '+').replace(/_/g, '/');
    const rawData = window.atob(base64);
    const outputArray = new Uint8Array(rawData.length);
    for (let i = 0; i < rawData.length; ++i) {
      outputArray[i] = rawData.charCodeAt(i);
    }
    return outputArray;
  }

  // Update visual state flags for existing push subscription settings
  if (pushToggleBtn && typeof window !== 'undefined' && 'Notification' in window) {
    if (Notification.permission === 'granted') {
      pushToggleBtn.textContent = 'Notifications Enabled';
      pushToggleBtn.disabled = true;
    }
  }

  pushToggleBtn?.addEventListener('click', async () => {
    if (!pushStatusMessage || !pushToggleBtn) return;

    pushStatusMessage.classList.add('hidden');
    pushToggleBtn.textContent = 'Requesting system links...';
    pushToggleBtn.disabled = true;

    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      pushStatusMessage.textContent = 'Push communication profiles are unsupported on this system web browser';
      pushStatusMessage.className = 'text-xs font-semibold p-3 mb-3 bg-rose-50 text-rose-800 border border-rose-100 rounded-xl text-center';
      pushStatusMessage.classList.remove('hidden');
      pushToggleBtn.textContent = 'Enable Mobile Push Notifications';
      pushToggleBtn.disabled = false;
      return;
    }

    try {
      const permission = await Notification.requestPermission();
      if (permission !== 'granted') {
        throw new Error('System subscription alert clearance turned down by user context');
      }

      const registration = await navigator.serviceWorker.ready;
      
      const subscription = await registration.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(VAPID_PUBLIC_KEY)
      });

      const rawKeyBytes = subscription.getKey('p256dh');
      const rawAuthBytes = subscription.getKey('auth');

      const payload = {
        endpoint: subscription.endpoint,
        p256dh: rawKeyBytes ? btoa(String.fromCharCode(...new Uint8Array(rawKeyBytes))) : '',
        auth: rawAuthBytes ? btoa(String.fromCharCode(...new Uint8Array(rawAuthBytes))) : ''
      };

      const response = await fetch('/api/push-subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        throw new Error('Cloud database sync rejected device endpoints');
      }

      pushStatusMessage.textContent = 'Device token verification complete. Web push linked.';
      pushStatusMessage.className = 'text-xs font-semibold p-3 mb-3 bg-emerald-50 text-emerald-800 border border-emerald-100 rounded-xl text-center';
      pushStatusMessage.classList.remove('hidden');
      pushToggleBtn.textContent = 'Notifications Enabled';
    } catch (err: any) {
      pushStatusMessage.textContent = err.message;
      pushStatusMessage.className = 'text-xs font-semibold p-3 mb-3 bg-rose-50 text-rose-800 border border-rose-100 rounded-xl text-center';
      pushStatusMessage.classList.remove('hidden');
      pushToggleBtn.textContent = 'Enable Mobile Push Notifications';
      pushToggleBtn.disabled = false;
    }
  });

  passwordForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!passwordMessage || !passwordSubmitBtn) return;

    passwordMessage.classList.add('hidden');
    passwordMessage.className = 'text-xs font-semibold p-3 rounded-xl text-center';
    passwordSubmitBtn.textContent = 'Saving changes...';
    (passwordSubmitBtn as HTMLButtonElement).disabled = true;

    const newPassword = (document.getElementById('new-password') as HTMLInputElement).value;

    try {
      const response = await fetch('/api/user/password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ newPassword })
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Failed to update credentials');
      }

      passwordMessage.textContent = 'Password updated successfully. Loading your dashboard...';
      passwordMessage.classList.add('bg-emerald-50', 'text-emerald-800', 'border', 'border-emerald-100');
      passwordMessage.classList.remove('hidden');

      setTimeout(() => {
        window.location.href = '/dashboard';
      }, 1500);

    } catch (err: any) {
      passwordMessage.textContent = err.message;
      passwordMessage.classList.add('bg-rose-50', 'text-rose-800', 'border', 'border-rose-100');
      passwordMessage.classList.remove('hidden');
      passwordSubmitBtn.textContent = 'Save New Password';
      (passwordSubmitBtn as HTMLButtonElement).disabled = false;
    }
  });

  signOutBtn?.addEventListener('click', async () => {
    await fetch('/api/auth', { method: 'DELETE' });
    window.location.href = '/login';
  });
</script>
