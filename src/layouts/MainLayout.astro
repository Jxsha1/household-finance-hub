---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-GB" class="h-full bg-slate-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#BAE6FD" />
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
    <title>{title} | Household Finance Hub</title>
  </head>
  <body class="h-full font-sans antialiased text-slate-800 flex flex-col justify-between select-none">
    
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -left-40 w-80 h-80 rounded-full bg-sky-100/60 blur-3xl"></div>
      <div class="absolute top-1/3 -right-20 w-70 h-70 rounded-full bg-emerald-50/70 blur-3xl"></div>
    </div>

    <header class="sticky top-0 z-40 w-full max-w-md mx-auto bg-white/75 backdrop-blur-md border-b border-sky-100/80 px-4 h-14 flex items-center justify-between shadow-sm">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-tr from-sky-300 to-emerald-300 flex items-center justify-center shadow-inner">
          <span class="text-white text-xs font-bold">£</span>
        </div>
        <span class="text-sm font-semibold tracking-tight text-slate-700">FinanceHub</span>
      </div>
      <slot name="header-actions" />
    </header>

    <main class="flex-1 w-full max-w-md mx-auto px-4 py-4 pb-24 overflow-y-auto">
      <slot />
    </main>

    <nav class="fixed bottom-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-t border-slate-100 shadow-lg">
      <div class="max-w-md mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/dashboard" class="flex flex-col items-center justify-center flex-1 py-1 text-sky-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          <span class="text-[10px] font-semibold mt-1">Home</span>
        </a>
        <a href="/transactions" class="flex flex-col items-center justify-center flex-1 py-1 text-slate-400 hover:text-sky-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-[10px] font-semibold mt-1">Activity</span>
        </a>
        <a href="/budgets" class="flex flex-col items-center justify-center flex-1 py-1 text-slate-400 hover:text-sky-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" />
          </svg>
          <span class="text-[10px] font-semibold mt-1">Budgets</span>
        </a>
        <a href="/settings" class="flex flex-col items-center justify-center flex-1 py-1 text-slate-400 hover:text-sky-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.43l-1.003.767c-.3.23-.45.62-.41.99.004.037.006.075.006.113 0 .038-.002.076-.006.114-.04.37.11.76.41.99l1.003.767a1.125 1.125 0 01.26 1.43l-1.296 2.247a1.125 1.125 0 01-1.37.49l-1.216-.456c-.356-.133-.751-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.43l1.004-.767c.304-.23.454-.62.41-.99a.53.53 0 00-.006-.113c0-.038.002-.076.006-.114.044-.37-.106-.76-.41-.99l-1.004-.767a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.49l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="text-[10px] font-semibold mt-1">Settings</span>
        </a>
      </div>
    </nav>

    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then(reg => console.log('Service Worker connection online', reg.scope))
            .catch(err => console.error('Service Worker connection offline', err));
        });
      }
    </script>
  </body>
</html>
