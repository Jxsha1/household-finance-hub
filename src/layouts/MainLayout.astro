---
interface Props {
  title: string
}

const { title } = Astro.props
const user = (Astro.locals as any).user
---

<!DOCTYPE html>
<html lang="en-GB" class="h-full bg-slate-50/50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Household Finance Hub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
    <style is:global>
      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
      }
      .font-mono {
        font-family: 'JetBrains Mono', monospace;
      }
    </style>
  </head>
  <body class="h-full flex flex-col md:flex-row text-slate-800 antialiased selection:bg-sky-100 selection:text-sky-900">
    
    <!-- Left Hand Sidebar Navigation Frame Panel Container -->
    <aside class="w-full md:w-64 bg-white border-b md:border-b-0 md:border-r border-slate-100 flex flex-col shrink-0">
      <div class="h-16 px-6 border-b border-slate-100/60 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-lg bg-sky-600 flex items-center justify-center text-white shadow-sm shadow-sky-200">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.007m0-.007v14.25m0-14.25c.41 0 .742.333.742.743v13.513c0 .41-.333.742-.743.742M6.75 22.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v13.5A2.25 2.25 0 006.75 22.5z" />
            </svg>
          </div>
          <span class="text-xs font-black uppercase tracking-wider text-slate-800">Finance Hub</span>
        </div>
      </div>

      <!-- Main Sidebar Directory Redirection Navigation Grid Links -->
      <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
        <a href="/dashboard" class="flex items-center gap-3 px-4 h-11 text-xs font-bold text-slate-600 rounded-xl hover:bg-slate-50 transition-colors">
          <span>Dashboard</span>
        </a>
        <a href="/recurring-payments" class="flex items-center gap-3 px-4 h-11 text-xs font-bold text-slate-600 rounded-xl hover:bg-slate-50 transition-colors">
          <span>Recurring Payments</span>
        </a>
        <a href="/transactions" class="flex items-center gap-3 px-4 h-11 text-xs font-bold text-slate-600 rounded-xl hover:bg-slate-50 transition-colors">
          <span>Transactions Ledger</span>
        </a>
        <a href="/settings" class="flex items-center gap-3 px-4 h-11 text-xs font-bold text-slate-600 rounded-xl hover:bg-slate-50 transition-colors">
          <span>System Settings</span>
        </a>
      </nav>

      <!-- Active Logged In Session Household Identification Profile Badge Footer -->
      {user && (
        <div class="p-4 border-t border-slate-100 bg-slate-50/40 flex items-center justify-between">
          <div class="overflow-hidden">
            <p class="text-[11px] font-black text-slate-700 truncate">{user.email}</p>
            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider mt-0.5 truncate">Household Member</p>
          </div>
          <a href="/logout" class="p-1.5 text-slate-400 hover:text-rose-600 rounded-lg transition-colors" title="Sign Out of Session">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
            </svg>
          </a>
        </div>
      )}
    </aside>

    <!-- Main Dynamic Workspace Output Container Segment Frame Layout Area -->
    <div class="flex-1 flex flex-col min-w-0 overflow-y-auto">
      
      <!-- Upper Master Application Header Workspace Sub panel -->
      <header class="h-16 px-6 bg-white border-b border-slate-100 flex items-center justify-between shrink-0 sticky top-0 z-30">
        <div class="flex items-center gap-3">
          <h1 class="text-sm font-black text-slate-800 uppercase tracking-wide">{title}</h1>
        </div>
        
        <!-- Extensible Dynamic Action Workspace Header Slot Container -->
        <div class="flex items-center gap-3">
          <slot name="header-actions" />
        </div>
      </header>

      <!-- Primary Page Component Viewport Render Section Node -->
      <main class="flex-1 p-6 max-w-5xl w-full mx-auto">
        <slot />
      </main>

    </div>

  </body>
</html>
